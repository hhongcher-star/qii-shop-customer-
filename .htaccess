RewriteEngine On

# =========================================================
# 🔐 1. Force HTTPS（推荐）
# =========================================================
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:[0-9]+)?$ [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

RewriteRule ^$ index.php [L]
RewriteRule ^(index|shop|search|contact|receipt|sitemap)/?$ $1.php [L,QSA]

# =========================================================
# 🎯 2. Remove .php extension (for all PHP files)
#    /shop        -> shop.php
#    /contact     -> contact.php
#    /order/list  -> order/list.php
# =========================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/?$ $1.php [L]
